          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "if (pm.response.code === 200 && response.data) {\r",
                  "    response.data.forEach(p => {\r",
                  "        if (p.name === 'Indomie Goreng') pm.environment.set('product_id_active', p.id);\r",
                  "        if (p.name === 'Beras Sania 5kg') pm.environment.set('product_id_low_stock', p.id);\r",
                  "        if (p.name === 'Teh Botol Sosro') pm.environment.set('product_id_inactive', p.id);\r",
                  "        if (p.name === 'Kopi Kapal Api') pm.environment.set('product_id_out_of_stock', p.id);\r",
                  "        if (p.name === 'Produk Draft Testing') pm.environment.set('product_id_draft', p.id);\r",
                  "    });\r",
                  "    console.log('All product IDs mapped');\r",
                  "}"
                ],
                "type": "text/javascript",
